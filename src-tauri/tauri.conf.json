{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "qxp",
  "version": "0.17.6",
  "identifier": "chat.qxp.desktop",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:4040",
    "beforeDevCommand": "npm --prefix frontend run dev -- --host 127.0.0.1",
    "beforeBuildCommand": "npm --prefix frontend run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "qxp",
        "width": 1100,
        "height": 760,
        "minWidth": 800,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": true,
        "backgroundColor": "#0f0f10"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**"]
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["openpgp4fpr", "dcaccount", "dclogin", "mailto"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage", "dmg", "app", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "SocialNetworking",
    "shortDescription": "Self-hostable chatmail client",
    "longDescription": "qxp is a chatmail client packaged as a native desktop application. It bundles the deltachat-core daemon and its Svelte UI into a single window.",
    "macOS": {
      "signingIdentity": "-",
      "entitlements": "Entitlements.plist"
    }
  }
}
