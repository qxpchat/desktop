{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "qxp",
  "version": "0.1.0",
  "identifier": "chat.qxp.desktop",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "npm --prefix frontend run dev -- --host 127.0.0.1",
    "beforeBuildCommand": "npm --prefix frontend run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "qxp",
        "width": 1100,
        "height": 760,
        "minWidth": 800,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "dmg", "app", "msi", "nsis"],
    "icon": ["icons/icon.png"],
    "category": "SocialNetworking",
    "shortDescription": "Self-hostable Delta Chat client",
    "longDescription": "qxp is a Delta Chat client packaged as a native desktop application. It bundles the deltachat-core daemon and its Svelte UI into a single window."
  }
}
