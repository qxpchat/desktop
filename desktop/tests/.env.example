# E2E pool config. Pool is populated by `make test-accounts`, which spawns
# `qxp-web` and drives its RPC chain
# (add_account → set_config_from_qr → configure → get_config) — the daemon
# handles the chatmail protocol, not this script.

QXP_TEST_RELAY_QR=dcaccount:nine.testrun.org
QXP_TEST_POOL_SIZE=10
QXP_TEST_DISPLAY_NAME_PREFIX="qxp e2e"

# Slot creds (auto-filled by ensure-pool.mjs):
# QXP_TEST_ACCT_1_EMAIL=
# QXP_TEST_ACCT_1_PASSWORD=
# QXP_TEST_ACCT_2_EMAIL=
# QXP_TEST_ACCT_2_PASSWORD=
# ...
